<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" alignment="CENTER"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.chat.ChatController"
      style="-fx-padding: 20;">

    <Label fx:id="lblStatus"
           text="Trình trạng: Đang ngoại tuyến"
           style="-fx-text-fill: gray;"/>

    <TextArea fx:id="txtHistory"
              editable="false"
              wrapText="true"
              VBox.vgrow="ALWAYS"/>

    <HBox spacing="10">
        <TextField fx:id="txtMessage"
                   HBox.hgrow="ALWAYS"
                   promptText="Nhập tin nhắn..."/>

        <Button text="Gửi"
                onAction="#handleSend"
                defaultButton="true"/>
    </HBox>

</VBox>
